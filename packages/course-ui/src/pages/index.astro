---
import { getCollection } from 'astro:content'
import Layout from '../layouts/Layout.astro'
import { ProgressBar } from '../components/progress-bar'
import { DayCardList } from '../components/day-card-list'
import courseConfig from 'virtual:course-config'

const allLessons = await getCollection('lessons')
const sorted = allLessons
  .sort((a, b) => a.data.day - b.data.day)
  .map((l) => ({
    day: l.data.day,
    slug: l.slug,
    title: l.data.title,
    description: l.data.description,
  }))
---

<Layout
  title={courseConfig.title}
  description={courseConfig.description}
  courseTitle={courseConfig.title}
  storageKey={courseConfig.storageKey}
>
  <main class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-2 text-3xl font-bold">{courseConfig.title}</h1>
    <p class="mb-8 text-zinc-500">{courseConfig.description}</p>
    <ProgressBar total={sorted.length} client:load />
    <DayCardList lessons={sorted} client:load />
  </main>
</Layout>
